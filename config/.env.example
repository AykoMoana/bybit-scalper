# MEXC API Credentials
# Dapatkan dari: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here

# Trading Settings
SYMBOL=BSBUSDT
EXCHANGE=mexc

# Scalping Strategy
SPREAD_THRESHOLD=0.001        # 0.1% minimum spread to enter
TAKE_PROFIT_PCT=0.008         # 0.8% take profit
STOP_LOSS_PCT=0.005           # 0.5% stop loss
MAX_POSITION_USDT=50          # Max position size per trade
MAX_DAILY_LOSS_USDT=100       # Max daily loss before stopping
MAX_OPEN_POSITIONS=3          # Max concurrent positions

# Order Settings
ORDER_TYPE=LIMIT              # LIMIT or MARKET
TIME_IN_FORCE=GTC

# Risk Management
TRAILING_STOP=true
TRAILING_STOP_PCT=0.003       # 0.3% trailing stop
BREAK_EVEN_AFTER_PCT=0.004    # Move SL to breakeven after 0.4% profit

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scalper.log
